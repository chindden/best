#!name=小红书去水印-QuanX
#!desc=基于 2026-04-29 HAR：保留旧 API 脚本，同时增加 sns-na CDN 图片去参数重定向。
#!author=RuCu6,fmz200,modified

host, ads-img-qc.xhscdn.com, reject
host, ads-video-al.xhscdn.com, reject
host, ads-video-qc.xhscdn.com, reject
host, t-ads.xiaohongshu.com, reject

# 评论区/图片水印配置
^https?:\/\/ci\.xiaohongshu\.com\/system_config\/watermark url reject-img

# 新图片链路：当前 HAR 中保存图片实际走 sns-na CDN 预览参数，旧 api/sns 脚本不会触发。
# 这条把 w/608 + HF_PRV 预览图重定向为同对象原始直链。
^https?:\/\/(sns-na-i\d\.xhscdn\.com)\/([^?]+)\?imageView2\/2\/w\/\d+\/format\/(?:heif|webp|jpg|jpeg)\/q\/\d+(?:%7C|\|)imageMogr2\/strip&redImage\/frame\/0(?:\/enhance\/\d+)?(?:\/codec\/\d+)?&.* url 302 https://$1/$2

# 搜索页
^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d+\/search\/(banner_list|hot_list) url script-response-body https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/xiaohongshu/xiaohongshu.js
^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d+\/search\/(hint|trending)\? url script-response-body https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/xiaohongshu/xiaohongshu.js
^https?:\/\/(so|edith)\.xiaohongshu\.com\/api\/sns\/v\d+\/search\/notes\? url script-response-body https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/xiaohongshu/xiaohongshu.js

# 旧图片/视频 API 链路，当前 HAR 未出现，但保留兼容。
^https?:\/\/(edith|rec|www)\.xiaohongshu\.com\/api\/sns\/v\d+\/note\/(imagefeed|live_photo\/save) url script-response-body https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/xiaohongshu/xiaohongshu.js
^https?:\/\/(edith|rec|www)\.xiaohongshu\.com\/api\/sns\/v\d+\/(followfeed|homefeed)\? url script-response-body https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/xiaohongshu/xiaohongshu.js
^https?:\/\/(edith|rec|www)\.xiaohongshu\.com\/api\/sns\/(v2\/note\/feed|v3\/note\/videofeed)\? url script-response-body https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/xiaohongshu/xiaohongshu.js
^https?:\/\/(edith|rec|www)\.xiaohongshu\.com\/api\/sns\/(v4\/note\/videofeed|v10\/note\/video\/save)\? url script-response-body https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/xiaohongshu/xiaohongshu.js

# 评论区
^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/(v5\/note\/comment\/list|v3\/note\/comment\/sub_comments)\? url script-response-body https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/xiaohongshu/xiaohongshu.js
^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v1\/interaction\/comment\/video\/download\? url script-response-body https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/xiaohongshu/xiaohongshu.js

hostname = %APPEND% edith.xiaohongshu.com, www.xiaohongshu.com, ci.xiaohongshu.com, rec.xiaohongshu.com, so.xiaohongshu.com, sns-na-i1.xhscdn.com, sns-na-i2.xhscdn.com, sns-na-i3.xhscdn.com, sns-na-i4.xhscdn.com, sns-na-i6.xhscdn.com
